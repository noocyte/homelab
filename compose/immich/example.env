# =============================================
# Immich Environment Variables
# =============================================

IMMICH_VERSION=release

# === STORAGE PATHS ===
UPLOAD_LOCATION=/mnt/zfs/immich/library
THUMB_LOCATION=/mnt/zfs/immich/thumbs
ENCODED_VIDEO_LOCATION=/mnt/zfs/immich/encoded-video
PROFILE_LOCATION=/mnt/zfs/immich/profile
BACKUP_LOCATION=/mnt/zfs/immich/backups

# Postgres on SSD (VM root filesystem)
DB_DATA_LOCATION=/var/lib/immich/postgres

# === DATABASE ===
DB_HOSTNAME=immich_postgres
DB_USERNAME=postgres
DB_PASSWORD=SecurePassword! #Change this
DB_DATABASE_NAME=immich

# === REDIS ===
REDIS_HOSTNAME=immich_redis

# === SECURITY ===
JWT_SECRET=SuperSecureString! #Change this

TZ=Europe/Oslo
